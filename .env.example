# ── Tastytrade ────────────────────────────────────────────────
# Credenciales de cuenta Tastytrade
TT_USERNAME=tu_email@ejemplo.com
TT_PASSWORD=tu_contraseña

# Sesión serializada en base64 para Railway (sin login interactivo)
# Generar con: python login.py
# Se actualiza automáticamente por auto_renew.py cada 6h
TT_SESSION_JSON=

# ── Railway (para auto-renovación de sesión) ──────────────────
# railway.app → Account Settings → Tokens → Create Token
RAILWAY_API_TOKEN=
# railway.app → Project → Settings → General → Project ID
RAILWAY_PROJECT_ID=
# railway.app → Service → Settings → Service ID
RAILWAY_SERVICE_ID=
# railway.app → Environments → (hover sobre env) → Copy ID
RAILWAY_ENVIRONMENT_ID=

# ── Telegram ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=tu_bot_token
TELEGRAM_CHAT_ID=id_canal_alertas_suscriptores
TELEGRAM_PRIVATE_CHAT_ID=id_chat_privado_operador

# ── Subyacentes ───────────────────────────────────────────────
WATCH_SYMBOLS=/ES

# ── Filtros globales de contrato ──────────────────────────────
MIN_CONTRACT_PRICE=7.00
MAX_STRIKE_DISTANCE_PCT=0.15

# ── Sweep Burst ───────────────────────────────────────────────
SWEEP_BURST_WINDOW_SECONDS=60
SWEEP_BURST_MIN_CONTRACTS=5
SWEEP_BURST_MIN_VOL=50
SWEEP_BURST_MIN_CONTRACTS_B=3
SWEEP_BURST_MIN_VOL_B=50
MIN_DELTA=0.30
MAX_DELTA=0.95
ALERT_COOLDOWN_SECONDS=120

# ── Block Print ───────────────────────────────────────────────
BLOCK_PRINT_MIN_DELTA=0.40
BLOCK_PRINT_MAX_DELTA=0.90
BLOCK_PRINT_COOLDOWN_SECONDS=120
# Horario de mercado (9:01–17:59 ET)
BLOCK_PRINT_MARKET_MIN_VOL=150
BLOCK_PRINT_MARKET_MIN_DELTA=0.40
# Fuera de mercado (18:00–9:00 ET)
BLOCK_PRINT_AFTER_HOURS_MIN_VOL=100
BLOCK_PRINT_AFTER_HOURS_MIN_DELTA=0.30

# ── Pressure Cooker ───────────────────────────────────────────
PRESSURE_COOKER_2MIN_VOL=250
PRESSURE_COOKER_5MIN_VOL=500
PRESSURE_COOKER_COOLDOWN_SECONDS=120

# ── Modo Raw (debugging / calibración) ───────────────────────
RAW_ALERT_MODE=false
RAW_MIN_PRICE=10.00
RAW_MIN_VOL_1MIN=50
RAW_COOLDOWN_SECONDS=120
