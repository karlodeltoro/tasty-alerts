# ── Tastytrade OAuth ──────────────────────────────────────────
# Obtener corriendo: python setup_auth.py
TT_SECRET=tu_client_secret_de_developer_tastytrade_com
TT_REFRESH=tu_refresh_token

# ── Telegram ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=tu_bot_token
TELEGRAM_CHAT_ID=tu_chat_id

# ── Subyacentes ───────────────────────────────────────────────
WATCH_SYMBOLS=/ES

# ── Filtros (mismos defaults que Schwab) ──────────────────────
MIN_DELTA=0.30
MAX_DELTA=0.95
MIN_CONTRACT_PRICE=7.00
MAX_STRIKE_DISTANCE_PCT=0.15
ALERT_COOLDOWN_SECONDS=120

# ── Sweep Burst ───────────────────────────────────────────────
SWEEP_BURST_MIN_CONTRACTS=5
SWEEP_BURST_MIN_VOL=50
SWEEP_BURST_MIN_CONTRACTS_B=3
SWEEP_BURST_MIN_VOL_B=75

# ── Block Print ───────────────────────────────────────────────
BLOCK_PRINT_MIN_VOL=100
BLOCK_PRINT_MIN_DELTA=0.40
BLOCK_PRINT_MAX_DELTA=0.90
BLOCK_PRINT_COOLDOWN_SECONDS=120

# ── Pressure Cooker ───────────────────────────────────────────
PRESSURE_COOKER_2MIN_VOL=250
PRESSURE_COOKER_5MIN_VOL=500
PRESSURE_COOKER_COOLDOWN_SECONDS=120

# ── Modo Raw (desactivado por default) ────────────────────────
RAW_ALERT_MODE=false
RAW_MIN_PRICE=10.00
RAW_MIN_VOL_1MIN=50
RAW_COOLDOWN_SECONDS=120
